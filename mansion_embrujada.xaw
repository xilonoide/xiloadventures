        { "Id": "d3", "NodeType": "Action_ShowMessage", "X": 500, "Y": 50, "Properties": { "Message": "Ya has leído el diario del conde." } },
        { "Id": "d4", "NodeType": "Action_SetFlag", "X": 500, "Y": 150, "Properties": { "FlagName": "diario_leido", "Value": true } },
        { "Id": "d5", "NodeType": "Action_ShowMessage", "X": 700, "Y": 150, "Properties": { "Message": "El diario revela la terrible verdad: el Conde intentó resucitar a su amada esposa con magia negra. El ritual falló y condenó a todos los habitantes a un limbo eterno." } }
