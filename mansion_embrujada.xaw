    {
      "Id": "conv_sabio",
      "Name": "Diálogo con el Sabio Errante",
      "Nodes": [
        { "Id": "s1", "NodeType": "Conversation_Start", "X": 100, "Y": 100, "Properties": {} },
        { "Id": "s2", "NodeType": "Conversation_NpcSay", "X": 300, "Y": 100, "Properties": { "Text": "Ah, otro alma valiente se aventura en esta mansión maldita.", "SpeakerName": "", "Emotion": "Neutral" } },
        { "Id": "s3", "NodeType": "Conversation_PlayerChoice", "X": 600, "Y": 100, "Properties": { "Text1": "¿Quién eres?", "Text2": "¿Sabes cómo romper la maldición?", "Text3": "Adiós", "Text4": "" } },
        { "Id": "s4", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 50, "Properties": { "Text": "Soy un viajero entre mundos. He visto muchas maldiciones, pero esta... es particularmente potente.", "SpeakerName": "", "Emotion": "Neutral" } },
        { "Id": "s5", "NodeType": "Conversation_Branch", "X": 900, "Y": 150, "Properties": { "ConditionType": "HasItem", "ItemId": "pergamino_ritual" } },
        { "Id": "s6", "NodeType": "Conversation_NpcSay", "X": 1200, "Y": 100, "Properties": { "Text": "Veo que has encontrado el pergamino. Bien. Necesitarás los tres objetos del poder y realizar el ritual a medianoche.", "SpeakerName": "", "Emotion": "Neutral" } },
        { "Id": "s7", "NodeType": "Conversation_Action", "X": 1500, "Y": 100, "Properties": { "ActionType": "SetFlag", "FlagName": "sabio_ritual_conocido" } },
        { "Id": "s8", "NodeType": "Conversation_NpcSay", "X": 1200, "Y": 200, "Properties": { "Text": "Busca el pergamino ritual en el estudio secreto. Allí encontrarás las respuestas.", "SpeakerName": "", "Emotion": "Neutral" } },
        { "Id": "s9", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 250, "Properties": { "Text": "Buena suerte, aventurero. Los espíritus cuentan contigo.", "SpeakerName": "", "Emotion": "Neutral" } },
        { "Id": "s10", "NodeType": "Conversation_End", "X": 1800, "Y": 150, "Properties": {} }
