{
  "Game": {
    "Id": "game",
    "Title": "La Mansión de los Susurros Olvidados",
    "Theme": "mansión embrujada",
    "StartRoomId": "vestibulo_entrada",
    "StartHour": 21,
    "StartWeather": "Tormenta",
    "MinutesPerGameHour": 6,
    "ParserDictionaryJson": "{\"nouns\": {\"espectro\": [\"fantasma\", \"aparición\", \"espíritu\"], \"orbe\": [\"esfera\", \"gema\"], \"grimorio\": [\"libro\", \"tomo\"]}}",
    "EncryptionKey": "M7xK9pL2",
    "EndingText": "Has roto la maldición que atormentaba la mansión durante siglos. Los espíritus inquietos finalmente pueden descansar en paz. Tu valentía será recordada en las crónicas de lo sobrenatural.",
    "CraftingEnabled": true,
    "CombatEnabled": true,
    "MagicEnabled": true,
    "BasicNeedsEnabled": true
  },
