    {
      "Id": "script_examinar_diario",
      "Name": "Examinar Diario del Conde",
      "OwnerType": "GameObject",
      "OwnerId": "diario_antiguo",
      "Nodes": [
        { "Id": "d1", "NodeType": "Event_OnExamine", "X": 100, "Y": 100, "Properties": {} },
