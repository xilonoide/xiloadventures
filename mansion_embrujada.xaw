  "Quests": [
    {
      "Id": "quest_romper_maldicion",
      "Name": "Romper la Maldición",
      "Description": "Descubre el origen de la maldición que ata los espíritus a la mansión y encuentra la manera de liberarlos.",
      "IsMainQuest": true,
      "Objectives": [
        "Explorar la mansión y descubrir su oscuro pasado",
        "Encontrar el diario del conde y el pergamino ritual",
        "Reunir los tres objetos del poder: Espada Maldita, Bastón Arcano y Armadura Espectral",
        "Realizar el ritual de destierro en la cripta durante la medianoche"
      ]
    },
    {
      "Id": "quest_espiritu_condesa",
      "Name": "El Lamento de la Condesa",
      "Description": "La Condesa Isabella busca algo. Ayúdala a encontrar paz.",
      "IsMainQuest": false,
      "Objectives": [
        "Hablar con el espíritu de la Condesa en el cementerio",
        "Encontrar el collar de esmeraldas que ella atesoraba",
        "Devolver el collar a la Condesa"
      ]
    },
    {
      "Id": "quest_comerciante_sombras",
      "Name": "Mercancía Sospechosa",
      "Description": "El Mercader de las Sombras tiene objetos valiosos pero pide un precio inusual.",
      "IsMainQuest": false,
      "Objectives": [
        "Conocer al Mercader de las Sombras en la bodega",
        "Completar sus peticiones comerciales para ganar su confianza",
        "Obtener información sobre objetos raros que puede conseguir"
      ]
    }
  ],
  "Conversations": [
    {
      "Id": "conv_mayordomo",
      "Name": "Diálogo con el Mayordomo Fantasma",
      "Nodes": [
        { "Id": "m1", "NodeType": "Conversation_Start", "X": 100, "Y": 100, "Properties": {} },
        { "Id": "m2", "NodeType": "Conversation_NpcSay", "X": 300, "Y": 100, "Properties": { "Text": "Bienvenido a la Mansión Blackwood, señor. Lamento el estado de la casa... han pasado tantos años.", "SpeakerName": "", "Emotion": "Triste" } },
        { "Id": "m3", "NodeType": "Conversation_PlayerChoice", "X": 600, "Y": 100, "Properties": { "Text1": "¿Qué sucedió aquí?", "Text2": "¿Puedes ayudarme?", "Text3": "Adiós", "Text4": "" } },
        { "Id": "m4", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 50, "Properties": { "Text": "El amo... el Conde Vladislav... experimentó con fuerzas que no debía. Ahora todos estamos atrapados.", "SpeakerName": "", "Emotion": "Triste" } },
        { "Id": "m5", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 150, "Properties": { "Text": "Solo puedo ofrecerle mi consejo, señor. La biblioteca contiene muchos secretos. Busque el diario del conde.", "SpeakerName": "", "Emotion": "Neutral" } },
        { "Id": "m6", "NodeType": "Conversation_Action", "X": 1200, "Y": 50, "Properties": { "ActionType": "SetFlag", "FlagName": "mayordomo_historia" } },
        { "Id": "m7", "NodeType": "Conversation_Action", "X": 1200, "Y": 150, "Properties": { "ActionType": "SetFlag", "FlagName": "mayordomo_consejo" } },
        { "Id": "m8", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 250, "Properties": { "Text": "Que tenga suerte, señor. Los espíritus son inquietos esta noche.", "SpeakerName": "", "Emotion": "Neutral" } },
        { "Id": "m9", "NodeType": "Conversation_End", "X": 1500, "Y": 150, "Properties": {} }
      ],
      "Connections": [
        { "FromNodeId": "m1", "FromPortName": "Exec", "ToNodeId": "m2", "ToPortName": "Exec" },
        { "FromNodeId": "m2", "FromPortName": "Exec", "ToNodeId": "m3", "ToPortName": "Exec" },
        { "FromNodeId": "m3", "FromPortName": "Option1", "ToNodeId": "m4", "ToPortName": "Exec" },
        { "FromNodeId": "m3", "FromPortName": "Option2", "ToNodeId": "m5", "ToPortName": "Exec" },
        { "FromNodeId": "m3", "FromPortName": "Option3", "ToNodeId": "m8", "ToPortName": "Exec" },
        { "FromNodeId": "m4", "FromPortName": "Exec", "ToNodeId": "m6", "ToPortName": "Exec" },
        { "FromNodeId": "m5", "FromPortName": "Exec", "ToNodeId": "m7", "ToPortName": "Exec" },
        { "FromNodeId": "m6", "FromPortName": "Exec", "ToNodeId": "m3", "ToPortName": "Exec" },
        { "FromNodeId": "m7", "FromPortName": "Exec", "ToNodeId": "m3", "ToPortName": "Exec" },
        { "FromNodeId": "m8", "FromPortName": "Exec", "ToNodeId": "m9", "ToPortName": "Exec" }
      ],
      "StartNodeId": "m1"
    },
    {
      "Id": "conv_mercader",
      "Name": "Diálogo con el Mercader de las Sombras",
      "Nodes": [
        { "Id": "c1", "NodeType": "Conversation_Start", "X": 100, "Y": 100, "Properties": {} },
        { "Id": "c2", "NodeType": "Conversation_NpcSay", "X": 300, "Y": 100, "Properties": { "Text": "Ssssss... viajero. Tengo mercancías que podrían interesssarte.", "SpeakerName": "", "Emotion": "Neutral" } },
        { "Id": "c3", "NodeType": "Conversation_PlayerChoice", "X": 600, "Y": 100, "Properties": { "Text1": "Muéstrame tu mercancía", "Text2": "¿Qué haces aquí?", "Text3": "Adiós", "Text4": "" } },
        { "Id": "c4", "NodeType": "Conversation_Shop", "X": 900, "Y": 50, "Properties": { "ShopTitle": "Mercancías Oscuras", "WelcomeMessage": "Mis preciosss... a buen precio." } },
        { "Id": "c5", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 150, "Properties": { "Text": "Comercio con aquellos que caminan entre sssombras. Todos necesitan algo, ¿no?", "SpeakerName": "", "Emotion": "Neutral" } },
        { "Id": "c6", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 250, "Properties": { "Text": "Vuelve cuando tengas monedassss...", "SpeakerName": "", "Emotion": "Neutral" } },
        { "Id": "c7", "NodeType": "Conversation_End", "X": 1200, "Y": 150, "Properties": {} }
      ],
      "Connections": [
        { "FromNodeId": "c1", "FromPortName": "Exec", "ToNodeId": "c2", "ToPortName": "Exec" },
        { "FromNodeId": "c2", "FromPortName": "Exec", "ToNodeId": "c3", "ToPortName": "Exec" },
        { "FromNodeId": "c3", "FromPortName": "Option1", "ToNodeId": "c4", "ToPortName": "Exec" },
        { "FromNodeId": "c3", "FromPortName": "Option2", "ToNodeId": "c5", "ToPortName": "Exec" },
        { "FromNodeId": "c3", "FromPortName": "Option3", "ToNodeId": "c6", "ToPortName": "Exec" },
        { "FromNodeId": "c4", "FromPortName": "OnClose", "ToNodeId": "c2", "ToPortName": "Exec" },
        { "FromNodeId": "c5", "FromPortName": "Exec", "ToNodeId": "c3", "ToPortName": "Exec" },
        { "FromNodeId": "c6", "FromPortName": "Exec", "ToNodeId": "c7", "ToPortName": "Exec" }
      ],
      "StartNodeId": "c1"
    },
    {
      "Id": "conv_condesa",
      "Name": "Diálogo con la Condesa",
      "Nodes": [
        { "Id": "co1", "NodeType": "Conversation_Start", "X": 100, "Y": 100, "Properties": {} },
        { "Id": "co2", "NodeType": "Conversation_NpcSay", "X": 300, "Y": 100, "Properties": { "Text": "*solloza* Mi amor... mi pobre amor... todo está perdido.", "SpeakerName": "", "Emotion": "Triste" } },
        { "Id": "co3", "NodeType": "Conversation_PlayerChoice", "X": 600, "Y": 100, "Properties": { "Text1": "¿Qué buscas?", "Text2": "¿Puedo ayudarte?", "Text3": "Adiós", "Text4": "" } },
        { "Id": "co4", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 50, "Properties": { "Text": "Mi collar... las esmeraldas que Vladislav me regaló. Era lo último que me quedaba de él.", "SpeakerName": "", "Emotion": "Triste" } },
        { "Id": "co5", "NodeType": "Conversation_Branch", "X": 900, "Y": 150, "Properties": { "ConditionType": "HasItem", "ItemId": "collar_esmeraldas" } },
        { "Id": "co6", "NodeType": "Conversation_NpcSay", "X": 1200, "Y": 100, "Properties": { "Text": "¡Mi collar! ¡Lo encontraste! Gracias... gracias, alma caritativa.", "SpeakerName": "", "Emotion": "Feliz" } },
        { "Id": "co7", "NodeType": "Conversation_Action", "X": 1500, "Y": 100, "Properties": { "ActionType": "RemoveItem", "ObjectId": "collar_esmeraldas" } },
        { "Id": "co8", "NodeType": "Conversation_Action", "X": 1800, "Y": 100, "Properties": { "ActionType": "CompleteQuest", "QuestId": "quest_espiritu_condesa" } },
        { "Id": "co9", "NodeType": "Conversation_NpcSay", "X": 2100, "Y": 100, "Properties": { "Text": "Ahora puedo descansar... Gracias, valiente aventurero.", "SpeakerName": "", "Emotion": "Feliz" } },
        { "Id": "co10", "NodeType": "Conversation_NpcSay", "X": 1200, "Y": 200, "Properties": { "Text": "Por favor... si lo encuentras, tráemelo.", "SpeakerName": "", "Emotion": "Triste" } },
        { "Id": "co11", "NodeType": "Conversation_Action", "X": 1500, "Y": 200, "Properties": { "ActionType": "StartQuest", "QuestId": "quest_espiritu_condesa" } },
        { "Id": "co12", "NodeType": "Conversation_NpcSay", "X": 900, "Y": 250, "Properties": { "Text": "Espero... siempre esperando...", "SpeakerName": "", "Emotion": "Triste" } },
        { "Id": "co13", "NodeType": "Conversation_End", "X": 2400, "Y": 150, "Properties": {} }
      ],
      "Connections": [
        { "FromNodeId": "co1", "FromPortName": "Exec", "ToNodeId": "co2", "ToPortName": "Exec" },
