  "Rooms": [
    {
      "Id": "vestibulo_entrada",
      "Name": "Vestíbulo de Entrada",
      "Description": "Un amplio vestíbulo en penumbra. La araña de cristal que cuelga del techo proyecta sombras danzantes. El polvo cubre cada superficie y el aire huele a humedad y abandono. Una escalera ascendente domina el centro de la estancia.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "salon_principal", "Direction": "norte", "DoorId": null },
        { "TargetRoomId": "biblioteca", "Direction": "este", "DoorId": "puerta_biblioteca" },
        { "TargetRoomId": "comedor", "Direction": "oeste", "DoorId": null },
        { "TargetRoomId": "pasillo_superior", "Direction": "arriba", "DoorId": null }
      ]
    },
    {
      "Id": "salon_principal",
      "Name": "Salón Principal",
      "Description": "Un vasto salón con muebles cubiertos por sábanas blancas. Los retratos en las paredes parecen seguirte con la mirada. Una chimenea apagada domina una pared.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "vestibulo_entrada", "Direction": "sur", "DoorId": null },
        { "TargetRoomId": "galeria_arte", "Direction": "norte", "DoorId": null },
        { "TargetRoomId": "sala_musica", "Direction": "este", "DoorId": "puerta_musica" }
      ]
    },
    {
      "Id": "biblioteca",
      "Name": "Biblioteca",
      "Description": "Estanterías hasta el techo repletas de libros antiguos. El olor a papel viejo impregna el aire. Una ventana rota deja entrar el viento frío de la noche.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "vestibulo_entrada", "Direction": "oeste", "DoorId": "puerta_biblioteca" },
        { "TargetRoomId": "estudio_secreto", "Direction": "norte", "DoorId": "puerta_estudio" }
      ]
    },
    {
      "Id": "comedor",
      "Name": "Comedor",
      "Description": "Una larga mesa de roble ocupa el centro. Los cubiertos están dispuestos como si esperaran comensales que nunca llegaron. Telarañas cuelgan de la lámpara central.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "vestibulo_entrada", "Direction": "este", "DoorId": null },
        { "TargetRoomId": "cocina", "Direction": "oeste", "DoorId": null },
        { "TargetRoomId": "bodega", "Direction": "abajo", "DoorId": "trampilla_bodega" }
      ]
    },
    {
      "Id": "cocina",
      "Name": "Cocina",
      "Description": "Una cocina antigua con un gran fogón de hierro. Ollas y cacerolas cuelgan de ganchos oxidados. El olor a moho es intenso.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "comedor", "Direction": "este", "DoorId": null },
        { "TargetRoomId": "despensa", "Direction": "norte", "DoorId": null }
      ]
    },
    {
      "Id": "despensa",
      "Name": "Despensa",
      "Description": "Una pequeña despensa con estanterías vacías. Algunos frascos rotos yacen en el suelo. Ratones han hecho nidos en los rincones.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "cocina", "Direction": "sur", "DoorId": null }
      ]
    },
    {
      "Id": "bodega",
      "Name": "Bodega",
      "Description": "Una bodega húmeda y fría. Barriles de vino apilados contra las paredes. El suelo de piedra está resbaladizo por el musgo.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "comedor", "Direction": "arriba", "DoorId": "trampilla_bodega" },
        { "TargetRoomId": "cripta", "Direction": "norte", "DoorId": "puerta_cripta" }
      ]
    },
    {
      "Id": "cripta",
      "Name": "Cripta Familiar",
      "Description": "Una cripta subterránea con sarcófagos de mármol. Velas fantasmales arden con llama azul. El aire es gélido y se escuchan susurros ininteligibles.",
      "IsInterior": true,
      "IsIlluminated": true,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "bodega", "Direction": "sur", "DoorId": "puerta_cripta" }
      ]
    },
    {
      "Id": "pasillo_superior",
      "Name": "Pasillo Superior",
      "Description": "Un largo pasillo con alfombra raída. Puertas a ambos lados conducen a las habitaciones. Cuadros de antiguos propietarios adornan las paredes.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "vestibulo_entrada", "Direction": "abajo", "DoorId": null },
        { "TargetRoomId": "dormitorio_principal", "Direction": "norte", "DoorId": "puerta_dormitorio" },
        { "TargetRoomId": "habitacion_huespedes", "Direction": "este", "DoorId": null },
        { "TargetRoomId": "torre_este", "Direction": "arriba", "DoorId": null }
      ]
    },
    {
      "Id": "dormitorio_principal",
      "Name": "Dormitorio Principal",
      "Description": "Una habitación lujosa con una cama con dosel. Cortinas de terciopelo rojo cubren las ventanas. Un espejo agrietado refleja sombras extrañas.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "pasillo_superior", "Direction": "sur", "DoorId": "puerta_dormitorio" },
        { "TargetRoomId": "vestidor", "Direction": "oeste", "DoorId": null }
      ]
    },
    {
      "Id": "vestidor",
      "Name": "Vestidor",
      "Description": "Un pequeño vestidor con armarios antiguos. Vestidos y trajes cuelgan como espectros silenciosos. Huele a naftalina y lavanda marchita.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "dormitorio_principal", "Direction": "este", "DoorId": null }
      ]
    },
    {
      "Id": "habitacion_huespedes",
      "Name": "Habitación de Huéspedes",
      "Description": "Una habitación modesta con cama individual y mesita de noche. Las sábanas están arrugadas como si alguien hubiera dormido recientemente.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "pasillo_superior", "Direction": "oeste", "DoorId": null },
        { "TargetRoomId": "bano", "Direction": "norte", "DoorId": null }
      ]
    },
    {
      "Id": "bano",
      "Name": "Baño",
      "Description": "Un baño antiguo con bañera con patas de león. El grifo gotea constantemente. El espejo está empañado aunque no hay vapor.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "habitacion_huespedes", "Direction": "sur", "DoorId": null }
      ]
    },
    {
      "Id": "torre_este",
      "Name": "Torre Este",
      "Description": "La habitación circular de la torre. Ventanas en todas direcciones ofrecen vistas de los terrenos abandonados. Una escalera de caracol asciende.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "pasillo_superior", "Direction": "abajo", "DoorId": null },
        { "TargetRoomId": "observatorio", "Direction": "arriba", "DoorId": null }
      ]
    },
    {
      "Id": "observatorio",
      "Name": "Observatorio",
      "Description": "La cúpula superior con un telescopio antiguo apuntando al cielo. Mapas estelares cubren las paredes. La tormenta golpea el cristal de la cúpula.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "torre_este", "Direction": "abajo", "DoorId": null }
      ]
    },
    {
      "Id": "galeria_arte",
      "Name": "Galería de Arte",
      "Description": "Una galería con pinturas de paisajes oscuros y retratos inquietantes. Algunas pinturas parecen cambiar cuando no las miras directamente.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "salon_principal", "Direction": "sur", "DoorId": null },
        { "TargetRoomId": "invernadero", "Direction": "norte", "DoorId": null }
      ]
    },
    {
      "Id": "invernadero",
      "Name": "Invernadero",
      "Description": "Un invernadero con cristales rotos. Plantas marchitas y enredaderas salvajes se han apoderado del espacio. La lluvia entra por los agujeros del techo.",
      "IsInterior": false,
      "IsIlluminated": true,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "galeria_arte", "Direction": "sur", "DoorId": null },
        { "TargetRoomId": "jardin_trasero", "Direction": "oeste", "DoorId": null }
      ]
    },
    {
      "Id": "jardin_trasero",
      "Name": "Jardín Trasero",
      "Description": "Un jardín invadido por maleza. Estatuas cubiertas de musgo vigilan senderos apenas visibles. Un pozo abandonado se encuentra en el centro.",
      "IsInterior": false,
      "IsIlluminated": true,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "invernadero", "Direction": "este", "DoorId": null },
        { "TargetRoomId": "capilla", "Direction": "norte", "DoorId": null }
      ]
    },
    {
      "Id": "capilla",
      "Name": "Capilla Abandonada",
      "Description": "Una pequeña capilla familiar. Los vitrales están rotos y la lluvia moja los bancos de madera. Un altar desmoronado preside el espacio.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "jardin_trasero", "Direction": "sur", "DoorId": null },
        { "TargetRoomId": "cementerio", "Direction": "norte", "DoorId": "puerta_cementerio" }
      ]
    },
    {
      "Id": "cementerio",
      "Name": "Cementerio Familiar",
      "Description": "Un cementerio sombrío rodeado por un muro de piedra. Las lápidas están inclinadas y cubiertas de líquenes. Niebla espesa se arrastra entre las tumbas.",
      "IsInterior": false,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "capilla", "Direction": "sur", "DoorId": "puerta_cementerio" },
        { "TargetRoomId": "panteon", "Direction": "norte", "DoorId": "puerta_panteon" }
      ]
    },
    {
      "Id": "panteon",
      "Name": "Panteón",
      "Description": "El mausoleo familiar, una estructura de mármol negro. Inscripciones antiguas advierten a los intrusos. Una energía opresiva emana del interior.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "cementerio", "Direction": "sur", "DoorId": "puerta_panteon" }
      ]
    },
    {
      "Id": "sala_musica",
      "Name": "Sala de Música",
      "Description": "Un salón con un piano de cola cubierto de polvo. Partituras esparcidas por el suelo. A veces se escuchan melodías fantasmales.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "salon_principal", "Direction": "oeste", "DoorId": "puerta_musica" }
      ]
    },
    {
      "Id": "estudio_secreto",
      "Name": "Estudio Secreto",
      "Description": "Un estudio oculto repleto de objetos ocultistas. Círculos de invocación dibujados en el suelo. Libros de magia negra apilados en el escritorio.",
      "IsInterior": true,
      "IsIlluminated": false,
      "MusicId": null,
      "Exits": [
        { "TargetRoomId": "biblioteca", "Direction": "sur", "DoorId": "puerta_estudio" }
      ]
    }
